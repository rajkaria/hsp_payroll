{
  "name": "@hashpay/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the HashPay Income Protocol — lets any LLM agent or human read and write payroll, reputation, yield, advance, and compliance primitives across EVM chains.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hashpay-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "example:agent": "tsx examples/agent-manager.ts",
    "example:reputation": "tsx examples/reputation-lookup.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "hashpay",
    "payroll",
    "web3",
    "ethereum",
    "reputation",
    "agents",
    "ai"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "@ledgerhq/hw-app-eth": "^6.39.0",
    "@ledgerhq/hw-transport-node-hid": "^6.29.0",
    "@walletconnect/sign-client": "^2.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rajkaria/hsp_payroll",
    "directory": "mcp"
  },
  "publishConfig": {
    "access": "public"
  }
}
